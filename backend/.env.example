# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# cp .env.example .env

# === Wajib ===
# API Key Gemini dari Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === Opsional ===
# Port server (default: 8080)
PORT=8080

# Mode Gin: debug / release (default: debug)
GIN_MODE=debug
